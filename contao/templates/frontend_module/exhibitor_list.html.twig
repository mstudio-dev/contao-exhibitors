{% extends "@Contao/frontend_module/_base.html.twig" %}

{% block content %}
    {% if rows is not empty %}
        <div class="exhibitor-list-wrap">
            <table class="exhibitor-list">
                <thead>
                    <tr>
                        <th class="ex-logo">{{ 'MSC.exhibitor_logo'|trans({}, 'contao_default') ?: 'Logo' }}</th>
                        <th class="ex-name">{{ 'tl_exhibitor.firmenname.0'|trans({}, 'contao_tl_exhibitor') ?: 'Firmenname' }}</th>
                        <th class="ex-stand">{{ 'tl_exhibitor.standplatz.0'|trans({}, 'contao_tl_exhibitor') ?: 'Standplatz' }}</th>
                        <th class="ex-status">{{ 'tl_exhibitor.reserviert.0'|trans({}, 'contao_tl_exhibitor') ?: 'Status' }}</th>
                        <th class="ex-website">{{ 'tl_exhibitor.website.0'|trans({}, 'contao_tl_exhibitor') ?: 'Website' }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                        <tr class="exhibitor-row{% if row.reserviert %} reserved{% endif %}">
                            <td class="ex-logo">
                                {% if row.logoPath %}
                                    <img
                                        src="{{ row.logoPath }}"
                                        alt="{{ row.logoAlt }}"
                                        class="exhibitor-logo"
                                        loading="lazy"
                                    >
                                {% endif %}
                            </td>
                            <td class="ex-name">{{ row.firmenname }}</td>
                            <td class="ex-stand">{{ row.standplatz }}</td>
                            <td class="ex-status">
                                {% if row.reserviert %}
                                    <span class="badge reserved">Reserviert</span>
                                {% else %}
                                    <span class="badge available">Verfügbar</span>
                                {% endif %}
                            </td>
                            <td class="ex-website">
                                {% if row.website %}
                                    <a
                                        href="{{ row.website }}"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    >{{ row.website|replace({'https://': '', 'http://': ''}) }}</a>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <p class="exhibitor-empty">Keine Aussteller vorhanden.</p>
    {% endif %}
{% endblock %}
