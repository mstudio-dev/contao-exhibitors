{
    "name": "mstudio-dev/contao-exhibitors",
    "description": "Contao 5 bundle for a tabular exhibitor list",
    "type": "contao-bundle",
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Markus Schnagl",
            "email": "mail@mstudio.de",
            "homepage": "https://mstudio.de",
            "role": "Developer"
        }
    ],
    "keywords": [
        "contao",
        "contao-bundle",
        "exhibitors",
        "aussteller"
    ],
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.0"
    },
    "require-dev": {
        "contao/manager-plugin": "^2.0"
    },
    "conflict": {
        "contao/manager-plugin": "<2.0 || >=3.0"
    },
    "autoload": {
        "psr-4": {
            "Mstudio\\ContaoExhibitorsBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "Mstudio\\ContaoExhibitorsBundle\\ContaoManager\\Plugin"
    }
}
